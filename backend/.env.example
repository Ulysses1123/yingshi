# 服务器配置
PORT=3000
NODE_ENV=development

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=yingshi_monitor

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 萤石云配置
YS_APP_KEY=your_app_key_here
YS_APP_SECRET=your_app_secret_here

# 街顺（外卖帮）即时零售 API 配置
# 文档: https://www.waisongbang.com/apiDoc/
JS_APP_KEY=your_app_key_here
JS_APP_SECRET=your_app_secret_here
JS_API_BASE=https://e.waisongbang.com/OpenApi
JS_THIRD_PARTNER_ID=5122

# Token 缓存时间（秒）- 默认5天
TOKEN_CACHE_TTL=432000
